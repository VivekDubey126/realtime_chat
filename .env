# .env - environment variables for Real‑Time Chat App
# -------------------------------------------------
# Google OAuth credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# MongoDB connection string (replace <username>, <password>, <dbname>)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# Session secret (choose a strong random string)
SESSION_SECRET=chatflow_secret_8d2f9k4s7m1p3n6v9x0z8y5w2q

# Server port (default 3000)
PORT=3000
